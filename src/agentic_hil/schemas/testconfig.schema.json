{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-hil.local/schemas/testconfig.schema.json",
  "title": "Agentic HIL test reactor configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "steps"],
  "properties": {
    "version": { "const": 1 },
    "name": { "type": "string", "minLength": 1 },
    "steps": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/flash" },
          { "$ref": "#/$defs/uartOpen" },
          { "$ref": "#/$defs/uartClose" },
          { "$ref": "#/$defs/debugStart" },
          { "$ref": "#/$defs/runUntilBreakpoint" },
          { "$ref": "#/$defs/dumpMemory" },
          { "$ref": "#/$defs/debugStop" }
        ]
      }
    }
  },
  "$defs": {
    "device": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+$" },
    "path": { "type": "string", "minLength": 1 },
    "timeout": { "type": "number", "minimum": 0 },
    "location": {
      "oneOf": [
        { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*(?:::[A-Za-z_][A-Za-z0-9_]*)*$" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["symbol"],
          "properties": {
            "symbol": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*(?:::[A-Za-z_][A-Za-z0-9_]*)*$" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["function"],
          "properties": {
            "function": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*(?:::[A-Za-z_][A-Za-z0-9_]*)*$" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["file", "line"],
          "properties": {
            "file": { "type": "string", "pattern": "^[A-Za-z0-9_./\\\\-]+$" },
            "line": { "type": "integer", "minimum": 1 }
          }
        }
      ]
    },
    "flash": {
      "type": "object",
      "additionalProperties": false,
      "required": ["device", "action", "image_path"],
      "properties": {
        "device": { "$ref": "#/$defs/device" },
        "action": { "const": "flash" },
        "image_path": { "$ref": "#/$defs/path" },
        "reset_after_flash": { "type": "boolean", "default": false }
      }
    },
    "uartOpen": {
      "type": "object",
      "additionalProperties": false,
      "required": ["device", "action"],
      "properties": {
        "device": { "$ref": "#/$defs/device" },
        "action": { "const": "uart_open" },
        "clear_buffer": { "type": "boolean", "default": true }
      }
    },
    "uartClose": {
      "type": "object",
      "additionalProperties": false,
      "required": ["device", "action"],
      "properties": {
        "device": { "$ref": "#/$defs/device" },
        "action": { "const": "uart_close" }
      }
    },
    "debugStart": {
      "type": "object",
      "additionalProperties": false,
      "required": ["device", "action", "image_path"],
      "properties": {
        "device": { "$ref": "#/$defs/device" },
        "action": { "const": "debug_start" },
        "image_path": { "$ref": "#/$defs/path" },
        "mode": { "type": "string", "enum": ["attach", "reset_halt", "load"], "default": "attach" },
        "timeout_s": { "$ref": "#/$defs/timeout" }
      }
    },
    "runUntilBreakpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["device", "action", "location"],
      "properties": {
        "device": { "$ref": "#/$defs/device" },
        "action": { "const": "run_until_breakpoint" },
        "location": { "$ref": "#/$defs/location" },
        "timeout_s": { "$ref": "#/$defs/timeout" }
      }
    },
    "dumpMemory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["device", "action", "symbol", "output_path"],
      "properties": {
        "device": { "$ref": "#/$defs/device" },
        "action": { "const": "dump_memory" },
        "symbol": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*(?:::[A-Za-z_][A-Za-z0-9_]*)*$" },
        "output_path": { "$ref": "#/$defs/path" }
      }
    },
    "debugStop": {
      "type": "object",
      "additionalProperties": false,
      "required": ["device", "action"],
      "properties": {
        "device": { "$ref": "#/$defs/device" },
        "action": { "const": "debug_stop" },
        "timeout_s": { "$ref": "#/$defs/timeout" }
      }
    }
  }
}
